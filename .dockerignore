# Version control
.git
.gitignore
.gitattributes

# Node / build artefacts
node_modules
.next
out
build
coverage
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env files — never bake these into the image.
.env
.env.*
!.env.example

# Editor / OS
.vscode
.idea
.DS_Store
*.swp

# Tests, docs, CI configs that aren't needed at runtime
.github
.husky
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
playwright-report
test-results

# Misc
README.md
AGENTS.md
CLAUDE.md
docker-compose*.yml
Dockerfile*
.dockerignore
