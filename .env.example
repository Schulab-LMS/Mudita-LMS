# ── App ──────────────────────────────────────────────────
NODE_ENV=production
# Canonical primary domain. Build-time public env — changing it requires a rebuild.
# (edu.mudita-solutions.de 301-redirects here; see docs/DOMAIN-CUTOVER.md)
NEXT_PUBLIC_APP_URL=https://schulab.com
# Set to "true" to enforce Content-Security-Policy (default: Report-Only). Flip only
# after beta traffic shows no legitimate CSP violations. Requires a rebuild.
CSP_ENFORCE=false
# Whether the public paid purchase flow is live. Default false for the soft-launch
# "payments OFF" beta: the pricing page shows "free in early access" instead of buyable
# plans. Flip to "true" once the subscribe flow + Stripe live catalog are wired+tested.
# Server-side only (not NEXT_PUBLIC) — change + restart, no rebuild needed.
PAYMENTS_ENABLED=false

# ── Database (Postgres Docker service name = "postgres") ─────
DB_USER=lms_user
DB_PASSWORD=change-this-strong-password
DB_NAME=mudita_lms
DATABASE_URL=postgresql://lms_user:change-this-strong-password@postgres:5432/mudita_lms

# ── Auth (NextAuth) ───────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-this-generate-with-openssl-rand-base64-32
AUTH_URL=https://schulab.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── File Upload (UploadThing) ─────────────────────────
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ── Email (Resend) ─────────────────────────────────
RESEND_API_KEY=
# From-address for outbound transactional email. Must be verified in Resend.
EMAIL_FROM=Schulab <noreply@schulab.com>
# Destination for contact-form submissions and "new tutor application"
# notifications. Falls back to admin@schulab.com if unset.
CONTACT_EMAIL=admin@schulab.com

# ── Stripe ────────────────────────────────────────
# Keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Default currency used when checkout does not explicitly pass one.
STRIPE_DEFAULT_CURRENCY=USD

# ── Video Hosting (pick one provider) ─────────────
# VIDEO_PROVIDER=MUX | CLOUDFLARE_STREAM | VIMEO | YOUTUBE | EXTERNAL
VIDEO_PROVIDER=EXTERNAL
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Required for signed playback. Without these, assets are served as public
# playback ids (fine for dev; NOT for paid courses).
MUX_SIGNING_KEY_ID=
# PKCS#8 PEM. MUST be on a single line with literal \n separators —
# docker --env-file and compose env_file do NOT support multi-line values
# and will fail the deploy with "variable '…' contains whitespaces".
# To convert a downloaded key file to the right shape:
#   awk '{printf "%s\\n", $0}' mux-signing-key.pem
# Paste the output (one line) directly after the = below.
MUX_SIGNING_KEY_PRIVATE=
# From Mux Dashboard → Settings → Webhooks. Used to verify signatures on
# POST /api/videos/mux/webhook.
MUX_WEBHOOK_SECRET=
CLOUDFLARE_STREAM_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=

# ── Product Analytics ─────────────────────────────
# ANALYTICS_PROVIDER=POSTHOG | GA4 | NONE
ANALYTICS_PROVIDER=NONE
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# ── Children's Data Compliance ────────────────────
# Ages below this value at signup require verified parental consent
# (COPPA=13 in the US, GDPR-K varies 13–16 per EU member state; DE is 16).
CHILD_AGE_THRESHOLD=16
# Latest version strings shown to users. Bump these when the documents
# are updated to force re-consent on next login.
TERMS_VERSION=2026-04-01
PRIVACY_VERSION=2026-04-01

# ── Legal entity (Impressum / Widerruf — German market) ──────
# These populate the Impressum (§5 TMG) and Widerrufsbelehrung pages. The pages
# fall back to "[Platzhalter]" strings when unset, which are NOT lawful to ship —
# fill EVERY field with real company data and have the pages reviewed by a German
# lawyer before launch. See docs/LEGAL-CHECKLIST.md.
COMPANY_LEGAL_NAME=Mudita IT Solutions UG (haftungsbeschränkt)
COMPANY_ADDRESS_LINE1=
COMPANY_ADDRESS_LINE2=
COMPANY_COUNTRY=Deutschland
COMPANY_EMAIL=hello@schulab.com
COMPANY_PHONE=
# Registergericht + HRB number (e.g. "Amtsgericht Berlin (Charlottenburg)" / "HRB 12345 B")
COMPANY_REGISTER_COURT=
COMPANY_REGISTER_NUMBER=
COMPANY_MANAGING_DIRECTOR=
# USt-IdNr. per §27a UStG (e.g. "DE123456789")
COMPANY_VAT_ID=
# Person responsible for content per §18 Abs. 2 MStV (name + address)
COMPANY_RESPONSIBLE_EDITOR=

# ── Rate Limiting (Redis) ─────────────────────────
# Shared counter for the sliding-window rate limiter. Without this every
# app instance keeps its own in-memory counter, so N replicas multiply the
# real limit by N. Leave unset for single-instance dev — the limiter falls
# back to an in-process Map.
REDIS_URL=

# ── Lifecycle Automation ──────────────────────────
# Shared secret required to call /api/cron/drip — supplied by the scheduler
# as "Authorization: Bearer <secret>". REQUIRED in production; an empty value
# causes the endpoint to return 503 to prevent unauthenticated drip triggers.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── Live Classroom (LiveKit) ──────────────────────
# Tutor-led live sessions ride on LiveKit Cloud rooms (data-channel only
# in P2; A/V tracks shipped in P3). Without all three values configured,
# the session page falls back to the static handout + external meetingUrl
# view. See src/lib/livekit.ts + src/services/live-classroom.service.ts.
# wss://… URL from the LiveKit Cloud project.
LIVEKIT_URL=
# API key + secret from the LiveKit Cloud project. The secret is also used
# to verify inbound webhook deliveries at /api/livekit/webhook.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Curriculum Sync (Git) ─────────────────────────
# The platform pulls all curriculum content from a private GitHub repo and
# syncs it into the Course/Module/Lesson tables. See
# src/services/curriculum-sync.service.ts.
# owner/name of the curriculum repo.
CURRICULA_REPO=Schulab-LMS/STEM-Curricula
# Branch to sync from (default: main).
CURRICULA_BRANCH=main
# Fine-grained, READ-ONLY GitHub PAT with "Contents: read" on the repo above.
# Used for the GitHub API + raw media fetches. Required to sync a private repo.
CURRICULA_GITHUB_TOKEN=
# Shared secret for the GitHub push webhook (POST /api/webhooks/curriculum).
# Set the same value as the webhook's secret in the repo settings. Verified
# as the HMAC-SHA256 "x-hub-signature-256" header. REQUIRED in production.
CURRICULA_WEBHOOK_SECRET=
