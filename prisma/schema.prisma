generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ========== AUTH & USERS ==========

enum Role {
  STUDENT
  PARENT
  TUTOR
  ADMIN
  SUPER_ADMIN
  B2B_PARTNER
  // Scoped admin for a single Organization (school / B2B partner). Can manage
  // users + courses within their own org but never across orgs. ADMIN /
  // SUPER_ADMIN remain the global-platform roles.
  ORG_ADMIN
}

// Multi-tenant scaffolding (Phase 1: nullable everywhere, not enforced).
// Lets us attach schools/organisations to users, courses, and bookings
// without a painful retrofit when tenant-scoping ships in Phase 4.
// See src/services/curriculum-sync.service.ts and the live-classroom plan.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  courses  Course[]
  bookings Booking[]
  bundles  Bundle[]
  pathways LearningPathway[]

  @@index([slug])
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  emailVerified    DateTime?
  passwordHash     String?
  name             String
  avatar           String?
  role             Role          @default(STUDENT)
  locale           String        @default("en")
  isActive         Boolean       @default(true)
  dateOfBirth      DateTime?
  stripeCustomerId String?       @unique
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  profile      Profile?
  tutorProfile TutorProfile?
  enrollments  Enrollment[]
  progress     LessonProgress[]
  quizAttempts QuizAttempt[]
  certificates Certificate[]
  badges       UserBadge[]
  points       PointTransaction[]

  bookingsAsStudent          Booking[]                 @relation("StudentBookings")
  orders                     Order[]
  coursePurchases            CoursePurchase[]          @relation("CoursePurchasePayer")
  coursePurchasesForChildren CoursePurchase[]          @relation("CoursePurchaseBeneficiary")
  subscriptions              Subscription[]
  invoices                   Invoice[]
  notifications              Notification[]
  sentMessages               Message[]                 @relation("SentMessages")
  receivedMessages           Message[]                 @relation("ReceivedMessages")
  competitionRegs            CompetitionRegistration[]
  consentRecords             ConsentRecord[]
  analyticsEvents            AnalyticsEvent[]

  parentOf      ParentChild[]   @relation("ParentRelation")
  childOf       ParentChild[]   @relation("ChildRelation")
  consentsGiven ConsentRecord[] @relation("ConsentGivenBy")

  courseReviews              CourseReview[]
  couponRedemptions          CouponRedemption[]
  auditLogs                  AuditLog[]
  onboardingProfile          OnboardingProfile?
  dripStates                 DripState[]
  activitySubmissions        ActivitySubmission[]        @relation("StudentSubmissions")
  tutorAssignmentTargets     TutorAssignment[]           @relation("TutorAssignmentStudent")
  tutorAssignmentSubmissions TutorAssignmentSubmission[] @relation("TutorAssignmentSubmissionStudent")
  studentAvailability        StudentAvailability[]
  lessonNotes                LessonNote[]                @relation("LessonNotes")
  lessonQuestions            LessonQuestion[]            @relation("LessonQuestionsAsked")
  lessonAnswers              LessonAnswer[]              @relation("LessonAnswersGiven")

  accounts Account[]
  sessions Session[]

  @@index([email])
  @@index([role])
  @@index([stripeCustomerId])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  bio         String?   @db.Text
  dateOfBirth DateTime?
  grade       String?
  school      String?
  country     String?
  phone       String?
  interests   String[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParentChild {
  id       String @id @default(cuid())
  parentId String
  childId  String
  parent   User   @relation("ParentRelation", fields: [parentId], references: [id])
  child    User   @relation("ChildRelation", fields: [childId], references: [id])

  createdAt DateTime @default(now())

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

// ========== COURSES & CONTENT ==========

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Lifecycle marker for Git-synced curriculum entities. Removal from the
// source repo flips this to REMOVED (soft-archive) instead of deleting the
// row, so dependent LessonProgress / QuizAttempt records are never lost.
enum SyncStatus {
  ACTIVE
  REMOVED
}

// Six learner age bands, aligned with the STEM-Curricula repo's authored
// stages (5-7, 8-10, 11-13…) and the public pathway bands. Shared by Course,
// Bundle, LearningPathway, Product and Competition so the platform has one age
// vocabulary everywhere.
enum AgeGroup {
  AGES_3_5
  AGES_5_7
  AGES_8_10
  AGES_11_13
  AGES_14_16
  AGES_17_18
}

// Provenance/readiness of a catalog item's content. Drives the admin "needs
// review" workflow and lets us distinguish freshly-seeded skeletons from
// imported content (e.g. NASA Space Place courses mapped into the new model).
enum ContentStatus {
  SEED_NOW // skeleton seeded, ready to author
  NEEDS_REVIEW // seeded, awaiting curriculum review before publish
  OPTIONAL_ENRICHMENT // nice-to-have enrichment content
  IMPORTED_EXISTING // mapped from pre-existing platform content
}

// Lifecycle of an external reference source (ScratchJr, NASA Space Place…).
enum SourceStatus {
  ACTIVE // current core source
  HISTORICAL // kept for inspiration only, not a live source
  OPTIONAL // optional/simulator-first or advanced use
  ENRICHMENT // enrichment only (articles, curiosity)
}

// Lifecycle of AI-assisted content as it moves through the source-first
// production pipeline (see docs/curriculum-production). Distinct from
// CourseStatus (catalog visibility) and ContentStatus (catalog readiness):
// this tracks the AI generation + human review handoff. A lesson must reach
// APPROVED (with a non-empty source citation set) before it may be PUBLISHED.
enum AiContentStatus {
  SOURCE_COLLECTED // approved-source passages gathered, nothing generated yet
  AI_GENERATED // drafted by the agent pipeline, awaiting review
  UNDER_REVIEW // a human reviewer is working through the checklist
  REVISION_NEEDED // sent back for changes
  APPROVED // signed off — eligible to publish
}

model Course {
  id                        String       @id @default(cuid())
  slug                      String       @unique
  title                     String
  titleAr                   String?
  titleDe                   String?
  description               String       @db.Text
  descriptionAr             String?      @db.Text
  descriptionDe             String?      @db.Text
  thumbnail                 String?
  previewVideo              String?
  level                     CourseLevel  @default(BEGINNER)
  ageGroup                  AgeGroup
  category                  String
  tags                      String[]
  // Catalog-page metadata. `skills` is what the learner gains; `tools` is the
  // software used (Scratch, Python…). Both locale-agnostic short labels.
  skills                    String[]     @default([])
  tools                     String[]     @default([])
  // Optional standalone capstone shown when the course is not inside a bundle.
  finalProjectTitle         String?
  finalProjectTitleAr       String?
  finalProjectTitleDe       String?
  finalProjectDescription   String?      @db.Text
  finalProjectDescriptionAr String?      @db.Text
  finalProjectDescriptionDe String?      @db.Text
  // Audience-specific blurbs for the course page; fall back to `description`.
  parentSummary             String?      @db.Text
  parentSummaryAr           String?      @db.Text
  parentSummaryDe           String?      @db.Text
  studentSummary            String?      @db.Text
  studentSummaryAr          String?      @db.Text
  studentSummaryDe          String?      @db.Text
  price                     Decimal      @default(0) @db.Decimal(10, 2)
  currency                  String       @default("USD")
  isFree                    Boolean      @default(false)
  // Marks a course as included with an active subscription whose plan tier
  // is >= the value set here. Nullable by design: the historical model is
  // "free (isFree) OR one-time purchase (price)", and we keep that working
  // untouched when requiredPlan is null. Tier order is FREE < LEARNER < PRO
  // < LIFETIME — see src/lib/subscription-access.ts.
  requiredPlan              PlanTier?
  status                    CourseStatus @default(DRAFT)
  duration                  Int?
  averageRating             Decimal      @default(0) @db.Decimal(3, 2)
  reviewCount               Int          @default(0)
  createdById               String
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  // Git-managed curriculum provenance. `managedByGit` flags a course whose
  // content is owned by the STEM-Curricula repo (read-only in the admin UI).
  // `sourcePath` is the course folder in the repo; `sourceCommitSha` is the
  // commit last synced. See src/services/curriculum-sync.service.ts.
  managedByGit    Boolean    @default(false)
  sourcePath      String?
  sourceCommitSha String?
  syncStatus      SyncStatus @default(ACTIVE)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Linear "next recommended course" pointer (self-relation). Rendered on the
  // course detail page; falls back to same-category related courses when null.
  nextCourseId String?
  nextCourse   Course?  @relation("CourseProgression", fields: [nextCourseId], references: [id], onDelete: SetNull)
  prevCourses  Course[] @relation("CourseProgression")

  // Course prerequisites (many-to-many self-relation via CoursePrerequisite).
  // `prerequisites` = courses that must be completed before enrolling in this
  // one; `requiredFor` = courses that list this course as a prerequisite.
  prerequisites CoursePrerequisite[] @relation("CourseRequires")
  requiredFor   CoursePrerequisite[] @relation("CoursePrereqOf")

  modules                Module[]
  enrollments            Enrollment[]
  reviews                CourseReview[]
  tutorAssignments       TutorAssignment[]
  tutorCourseAssignments TutorCourseAssignment[]

  // Catalog content readiness + free-form admin notes (see ContentStatus).
  contentStatus ContentStatus @default(SEED_NOW)
  adminNotes    String?       @db.Text

  // Course-level rollup of the AI-assisted production lifecycle. NULL for
  // hand-authored courses. Per-lesson detail lives on Lesson.aiStatus.
  aiStatus AiContentStatus?

  // Membership in bundles / pathway stages.
  bundleLinks   BundleCourse[]
  pathwayStages PathwayStage[]

  // External reference sources credited on the course page (badges + links).
  referenceSources CourseReferenceSource[]

  // Events/competitions this course helps prepare a learner for.
  eventRecommendations EventCourseRecommendation[]

  @@index([slug])
  @@index([category])
  @@index([ageGroup])
  @@index([status])
  @@index([requiredPlan])
  @@index([managedByGit])
  @@index([organizationId])
  @@index([nextCourseId])
  @@index([contentStatus])
}

// Explicit many-to-many self-relation: a course requires N prerequisite
// courses. A DB CHECK (added in the migration) prevents a course from listing
// itself. Enrolment is blocked until every prerequisite is COMPLETED — see
// getUnmetPrerequisites + the gate in enrollInCourse.
model CoursePrerequisite {
  id             String @id @default(cuid())
  courseId       String
  prerequisiteId String
  course         Course @relation("CourseRequires", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite   Course @relation("CoursePrereqOf", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteId])
  @@index([courseId])
  @@index([prerequisiteId])
}

model Module {
  id         String     @id @default(cuid())
  courseId   String
  title      String
  titleAr    String?
  titleDe    String?
  order      Int
  sourcePath String?
  syncStatus SyncStatus @default(ACTIVE)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  // Stable upsert key for Git-synced modules (NULL for admin-created ones;
  // Postgres treats NULLs as distinct, so non-managed rows are unaffected).
  @@unique([courseId, sourcePath])
  @@index([courseId])
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  INTERACTIVE
  ASSIGNMENT
  PRESENTATION
}

// How Reveal.js presentation content is authored. MARKDOWN is the default and
// preferred form — Reveal's markdown plugin parses it on the client. HTML is a
// future escape hatch for hand-crafted decks; sanitized server-side before
// store. P1 only emits MARKDOWN; the enum exists so we don't have to migrate
// again when HTML support lands.
enum PresentationFormat {
  MARKDOWN
  HTML
}

model Lesson {
  id                    String              @id @default(cuid())
  moduleId              String
  title                 String
  titleAr               String?
  titleDe               String?
  content               String?             @db.Text
  contentAr             String?             @db.Text
  contentDe             String?             @db.Text
  // Hands-on take-home activity (synced from activity.md). Student-visible.
  activity              String?             @db.Text
  activityAr            String?             @db.Text
  activityDe            String?             @db.Text
  // Tutor-only guidance (module overview + TUTOR_ONLY fences). NEVER served
  // to students — student-facing queries omit these columns by construction.
  tutorNotes            String?             @db.Text
  tutorNotesAr          String?             @db.Text
  tutorNotesDe          String?             @db.Text
  // Reveal.js slide deck (synced from presentation.md). Raw markdown is stored
  // so the client-side Reveal markdown plugin keeps slide-break semantics
  // ('---' / '--') intact. presentationConfig holds parsed YAML frontmatter
  // (theme, transition, plugins…). When presentationContent is non-null the
  // lesson's `type` is PRESENTATION and the renderer takes over the main
  // content surface.
  presentationFormat    PresentationFormat?
  presentationContent   String?             @db.Text
  presentationContentAr String?             @db.Text
  presentationContentDe String?             @db.Text
  presentationConfig    Json?
  // Downloadable resources / reference links, synced from the lesson folder:
  // a resources.md list, else the meta.yml source fields, else a "Resources"
  // section in the handout (see resolveResources in curriculum-structure.ts).
  // Stored as a JSON array of { title, url, type } (LessonResource).
  // Locale-agnostic: the links are shared across languages.
  resources             Json?
  videoUrl              String?
  videoAssetId          String?
  thumbnail             String?
  duration              Int?
  type                  LessonType          @default(VIDEO)
  order                 Int
  isFree                Boolean             @default(false)
  sourcePath            String?
  syncStatus            SyncStatus          @default(ACTIVE)

  // ── AI-assisted production provenance (see docs/curriculum-production) ──
  // NULL on hand-authored / pre-AI lessons. aiStatus gates publishing: a
  // lesson reaches PUBLISHED only when aiStatus = APPROVED and it carries at
  // least one source citation. aiModel records which sanctioned model produced
  // it (claude-opus-4-8 | claude-sonnet-4-6). aiReviewedById is the User id of
  // the human who signed off (plain id, mirrors createdById — no FK).
  aiStatus               AiContentStatus?
  aiModel                String?
  aiReviewedById         String?
  lastVerifiedAt         DateTime?
  tutorSupportRequired   Boolean          @default(false)
  parentGuidanceRequired Boolean          @default(false)

  module           Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz             Quiz?
  progress         LessonProgress[]
  sessions         Booking[]
  submissions      ActivitySubmission[]
  tutorAssignments TutorAssignment[]
  notes            LessonNote[]
  questions        LessonQuestion[]
  // Per-section source provenance (queryable mirror of the lesson meta.yml
  // citations). One row per generated section → supporting source passage.
  sourceCitations  LessonSourceCitation[]

  // Stable upsert key for Git-synced lessons (NULL for admin-created ones).
  @@unique([moduleId, sourcePath])
  @@index([moduleId])
  @@index([videoAssetId])
  @@index([aiStatus])
}

// ========== BUNDLES & PATHWAYS ==========

// A themed group of related courses (coding, AI, game design…) that ends in a
// final project. Access is subscription-first: gated by requiredPlan + the
// per-course purchase model. Price/isFree are declared for a future bundle
// checkout but are not charged in v1. Reusable across pathways.
model Bundle {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  titleAr       String?
  titleDe       String?
  description   String       @db.Text
  descriptionAr String?      @db.Text
  descriptionDe String?      @db.Text
  thumbnail     String?
  themeCategory String
  ageGroup      AgeGroup
  level         CourseLevel  @default(BEGINNER)
  status        CourseStatus @default(DRAFT)
  requiredPlan  PlanTier?
  isFree        Boolean      @default(false)
  price         Decimal      @default(0) @db.Decimal(10, 2)
  currency      String       @default("USD")

  // Capstone shown at the end of the bundle.
  finalProjectTitle         String?
  finalProjectTitleAr       String?
  finalProjectTitleDe       String?
  finalProjectDescription   String? @db.Text
  finalProjectDescriptionAr String? @db.Text
  finalProjectDescriptionDe String? @db.Text

  // Localized objective lists, shaped { en: string[], ar: string[], de: string[] }.
  // String[] can't carry per-locale variants, so JSON keeps i18n parity.
  learningObjectives       Json?
  recommendedDurationWeeks Int?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Git-sync parity (declared now so a future curriculum-sync of bundles
  // needs no second migration). Mirrors Course's provenance fields.
  managedByGit    Boolean    @default(false)
  sourcePath      String?
  sourceCommitSha String?
  syncStatus      SyncStatus @default(ACTIVE)

  adminNotes String? @db.Text

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses       BundleCourse[]
  pathwayStages PathwayStage[]
  certificates  Certificate[]
  submissions   ActivitySubmission[]

  // External reference sources credited on the bundle page.
  referenceSources BundleReferenceSource[]

  // Events/competitions this bundle helps prepare a learner for.
  eventRecommendations EventBundleRecommendation[]

  @@index([slug])
  @@index([themeCategory])
  @@index([ageGroup])
  @@index([status])
  @@index([requiredPlan])
  @@index([organizationId])
}

// Explicit ordered join: courses inside a bundle carry per-link attributes
// (order, required vs optional) that an implicit m2m can't store. Mirrors
// Module.order semantics; reorder rewrites `order` like reorderModules.
model BundleCourse {
  id         String  @id @default(cuid())
  bundleId   String
  courseId   String
  order      Int
  isRequired Boolean @default(true)
  bundle     Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  course     Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseId])
  @@index([bundleId, order])
  @@index([courseId])
}

// An age-based learning journey (beginner → advanced) made of ordered stages.
// One pathway per age band on the public site.
model LearningPathway {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  titleAr       String?
  titleDe       String?
  description   String       @db.Text
  descriptionAr String?      @db.Text
  descriptionDe String?      @db.Text
  thumbnail     String?
  ageGroup      AgeGroup
  status        CourseStatus @default(DRAFT)
  order         Int          @default(0)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  adminNotes String? @db.Text

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages PathwayStage[]

  // External reference sources credited on the pathway page.
  referenceSources PathwayReferenceSource[]

  // Events that point at this pathway as their preparation journey.
  preparesForEvents Competition[] @relation("EventPrepPath")

  @@index([slug])
  @@index([ageGroup])
  @@index([status])
  @@index([organizationId])
}

// One stage of a pathway. Points at EXACTLY ONE of a bundle or a course — a
// DB CHECK constraint (added by hand in the migration SQL, since Prisma can't
// express XOR) enforces it; addPathwayStageSchema mirrors it at the app layer.
model PathwayStage {
  id        String  @id @default(cuid())
  pathwayId String
  order     Int
  title     String?
  titleAr   String?
  titleDe   String?
  bundleId  String?
  courseId  String?

  pathway LearningPathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  bundle  Bundle?         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  course  Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([pathwayId, order])
  @@index([pathwayId, order])
  @@index([bundleId])
  @@index([courseId])
}

// ========== REFERENCE SOURCES ==========

// A real, reputable external source (ScratchJr, Scratch, Code.org, NASA Space
// Place, PhET…) credited across the catalog. Sources are platform-global and
// reused via the three join tables below. `key` is the stable seed handle used
// to attach a source without knowing its generated id. NO fabricated sources or
// URLs may be added — only verified providers (see seed catalog data).
model ReferenceSource {
  id                  String       @id @default(cuid())
  key                 String       @unique
  name                String
  url                 String
  provider            String
  sourceType          String
  relatedTopics       String[]     @default([])
  recommendedAgeRange String?
  usageInSchulab      String       @db.Text
  status              SourceStatus @default(ACTIVE)
  notes               String?      @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  courseLinks  CourseReferenceSource[]
  bundleLinks  BundleReferenceSource[]
  pathwayLinks PathwayReferenceSource[]
  // RAG knowledge-base chunks embedded from this source (see SourceChunk).
  chunks       SourceChunk[]

  @@index([key])
  @@index([status])
}

// Ordered course ↔ source join (a course cites many sources; a source is reused
// by many courses). `order` controls badge display order on the course page.
model CourseReferenceSource {
  id       String          @id @default(cuid())
  courseId String
  sourceId String
  order    Int             @default(0)
  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  source   ReferenceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([courseId, sourceId])
  @@index([courseId, order])
  @@index([sourceId])
}

model BundleReferenceSource {
  id       String          @id @default(cuid())
  bundleId String
  sourceId String
  order    Int             @default(0)
  bundle   Bundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  source   ReferenceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([bundleId, sourceId])
  @@index([bundleId, order])
  @@index([sourceId])
}

model PathwayReferenceSource {
  id        String          @id @default(cuid())
  pathwayId String
  sourceId  String
  order     Int             @default(0)
  pathway   LearningPathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  source    ReferenceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([pathwayId, sourceId])
  @@index([pathwayId, order])
  @@index([sourceId])
}

// ========== AI CURRICULUM PIPELINE ==========
// Provenance + RAG knowledge base for the AI-assisted production process.
// See docs/curriculum-production.

// One row per generated lesson section → the approved source passage that
// grounds it. Queryable mirror of the lesson meta.yml citations, so reviewers
// (and the publish gate) can assert "every section is source-backed" in SQL
// rather than parsing markdown. sourceKey is a soft reference to
// ReferenceSource.key; sourceUrl is the exact page cited.
model LessonSourceCitation {
  id             String    @id @default(cuid())
  lessonId       String
  section        String // handout | activity | presentation | quiz | video | …
  sourceKey      String? // ReferenceSource.key, if it maps to a catalog source
  sourceUrl      String?
  extractedNotes String?   @db.Text
  confidence     Float?
  reviewStatus   String? // ok | needs_human_review | needs_source
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([sourceKey])
}

// RAG knowledge base. Each approved ReferenceSource is fetched, chunked, and
// embedded; retrieval is gated to ACTIVE/OPTIONAL chunks for curriculum
// generation. The `embedding` column is pgvector — Unsupported() because the
// typed Prisma Client never reads it (vector similarity runs via raw SQL).
// The `vector` extension + the cosine index are created in the migration SQL.
model SourceChunk {
  id         String                       @id @default(cuid())
  sourceId   String
  chunkIndex Int
  content    String                       @db.Text
  url        String?
  license    String?
  ageRange   String?
  status     SourceStatus                 @default(ACTIVE)
  tokenCount Int?
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  source ReferenceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkIndex])
  @@index([status])
}

// ========== QUIZZES ==========

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

model Quiz {
  id           String        @id @default(cuid())
  lessonId     String        @unique
  title        String
  passingScore Int           @default(70)
  timeLimit    Int?
  lesson       Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]
}

model Question {
  id          String       @id @default(cuid())
  quizId      String
  text        String       @db.Text
  textAr      String?      @db.Text
  textDe      String?      @db.Text
  type        QuestionType @default(MULTIPLE_CHOICE)
  points      Int          @default(1)
  order       Int
  explanation String?      @db.Text
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     Answer[]

  @@index([quizId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  text       String
  textAr     String?
  textDe     String?
  isCorrect  Boolean  @default(false)
  order      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  answers     Json
  passed      Boolean
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([quizId])
}

// ========== ENROLLMENT & PROGRESS ==========

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  user        User             @relation(fields: [userId], references: [id])
  course      Course           @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  completed  Boolean  @default(false)
  timeSpent  Int      @default(0)
  lastAccess DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  lesson     Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId])
}

// A certificate is issued for EXACTLY ONE of a course or a bundle. courseId is
// nullable now that bundle certificates exist; a DB CHECK (added in the
// migration) enforces the XOR. courseId stays a plain string (no FK) to match
// the historical model; bundleId carries a real FK to Bundle.
model Certificate {
  id       String   @id @default(cuid())
  userId   String
  courseId String?
  bundleId String?
  code     String   @unique
  issuedAt DateTime @default(now())
  pdfUrl   String?
  user     User     @relation(fields: [userId], references: [id])
  bundle   Bundle?  @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  // Backstops the bundle-certificate dedup race: one cert per (user, bundle).
  // Harmless for course certs — their bundleId is NULL and Postgres treats
  // NULLs as distinct, so it imposes no constraint on the course path.
  @@unique([userId, bundleId])
  @@index([userId])
  @@index([code])
  @@index([bundleId])
}

enum ActivitySubmissionStatus {
  SUBMITTED
  REVIEWED
}

// A student's response to a lesson's hands-on activity, plus the tutor's
// feedback. One submission per (student, lesson); resubmitting updates it.
// A student's response to a lesson activity OR a bundle capstone (portfolio).
// Exactly one of (lessonId, bundleId) is set — a DB CHECK enforces the XOR.
// The two partial unique indexes give "one submission per (student, lesson)"
// and "one per (student, bundle)" while NULLs on the other side stay distinct.
model ActivitySubmission {
  id           String                   @id @default(cuid())
  lessonId     String?
  bundleId     String?
  studentId    String
  bookingId    String?
  content      String                   @db.Text
  status       ActivitySubmissionStatus @default(SUBMITTED)
  feedback     String?                  @db.Text
  feedbackById String?
  feedbackAt   DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  bundle  Bundle? @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  student User    @relation("StudentSubmissions", fields: [studentId], references: [id])

  @@unique([studentId, lessonId])
  @@unique([studentId, bundleId])
  @@index([lessonId])
  @@index([bundleId])
  @@index([bookingId])
}

enum TutorAssignmentKind {
  ASSIGNMENT
  QUIZ
  PROJECT
}

enum TutorAssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum TutorAssignmentSubmissionStatus {
  SUBMITTED
  REVIEWED
  RETURNED
}

// A tutor-authored task for one learner in a course they are enrolled in.
// Targeting one learner keeps authorization explicit and makes parent/student
// visibility deterministic. A later cohort feature can group several rows.
model TutorAssignment {
  id           String                @id @default(cuid())
  tutorId      String
  studentId    String
  courseId     String
  lessonId     String?
  title        String
  instructions String                @db.Text
  kind         TutorAssignmentKind   @default(ASSIGNMENT)
  status       TutorAssignmentStatus @default(PUBLISHED)
  dueAt        DateTime?
  maxPoints    Int                   @default(100)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  tutor       TutorProfile                @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  student     User                        @relation("TutorAssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  course      Course                      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson      Lesson?                     @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  submissions TutorAssignmentSubmission[]

  @@index([tutorId, status])
  @@index([studentId, status])
  @@index([courseId])
  @@index([dueAt])
}

model TutorAssignmentSubmission {
  id           String                          @id @default(cuid())
  assignmentId String
  studentId    String
  content      String                          @db.Text
  status       TutorAssignmentSubmissionStatus @default(SUBMITTED)
  points       Int?
  feedback     String?                         @db.Text
  feedbackById String?
  feedbackAt   DateTime?
  submittedAt  DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt

  assignment TutorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User            @relation("TutorAssignmentSubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId, status])
}

// A learner's private, personal note for a lesson. One row per (user, lesson);
// the Notes tab autosaves into it. Never shown to anyone but the author.
model LessonNote {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation("LessonNotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

// A learner's public question on a lesson (the Q&A tab). Visible to everyone
// enrolled in the course; answered by tutors / admins.
model LessonQuestion {
  id        String   @id @default(cuid())
  lessonId  String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson  Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  author  User           @relation("LessonQuestionsAsked", fields: [authorId], references: [id], onDelete: Cascade)
  answers LessonAnswer[]

  @@index([lessonId, createdAt])
  @@index([authorId])
}

// A staff (tutor / admin) reply to a lesson question. Single-level threads.
model LessonAnswer {
  id         String   @id @default(cuid())
  questionId String
  authorId   String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question LessonQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author   User           @relation("LessonAnswersGiven", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([questionId, createdAt])
  @@index([authorId])
}

// ========== CURRICULUM SYNC (Git) ==========

enum SyncRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SyncTrigger {
  WEBHOOK
  MANUAL
  CRON
}

// One row per curriculum sync attempt. Observability + admin "last synced"
// display. Written by src/services/curriculum-sync.service.ts.
model CurriculumSyncRun {
  id              String        @id @default(cuid())
  commitSha       String?
  status          SyncRunStatus @default(RUNNING)
  trigger         SyncTrigger
  coursesUpserted Int           @default(0)
  lessonsUpserted Int           @default(0)
  coursesArchived Int           @default(0)
  error           String?       @db.Text
  startedAt       DateTime      @default(now())
  finishedAt      DateTime?

  @@index([startedAt])
}

// ========== TUTORING ==========

model TutorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  headline      String?
  bio           String?  @db.Text
  subjects      String[]
  languages     String[]
  hourlyRate    Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  rating        Decimal  @default(0) @db.Decimal(3, 2)
  totalSessions Int      @default(0)
  isVerified    Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  availability      TutorAvailability[]
  bookings          Booking[]
  assignments       TutorAssignment[]
  courseAssignments TutorCourseAssignment[]
}

// Durable Admin-managed authorization for which curriculum a tutor may teach.
// Bookings establish the tutor↔learner relationship; this row establishes the
// independent tutor↔course permission used by lesson and assignment actions.
model TutorCourseAssignment {
  id           String   @id @default(cuid())
  tutorId      String
  courseId     String
  assignedById String?
  createdAt    DateTime @default(now())

  tutor  TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([tutorId, courseId])
  @@index([courseId])
}

model TutorAvailability {
  id        String       @id @default(cuid())
  tutorId   String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String       @default("UTC")
  tutor     TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
}

// Recurring weekly availability a student declares at onboarding. Mirrors
// TutorAvailability so overlap can be computed directly (see
// src/services/tutor-matching.service.ts).
model StudentAvailability {
  id        String @id @default(cuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String @default("UTC")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Booking {
  id               String            @id @default(cuid())
  studentId        String
  tutorId          String
  subject          String
  startTime        DateTime
  endTime          DateTime
  status           BookingStatus     @default(PENDING)
  meetingUrl       String?
  meetingId        String?
  notes            String?           @db.Text
  rating           Int?
  review           String?           @db.Text
  price            Decimal           @db.Decimal(10, 2)
  currency         String            @default("USD")
  createdAt        DateTime          @default(now())
  // The curriculum lesson taught in this session (set by the tutor). Drives
  // the role-split live-session view. Null until the tutor assigns one.
  lessonId         String?
  organizationId   String?
  student          User              @relation("StudentBookings", fields: [studentId], references: [id])
  tutor            TutorProfile      @relation(fields: [tutorId], references: [id])
  lesson           Lesson?           @relation(fields: [lessonId], references: [id])
  organization     Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  // Lazily created when the first participant joins the live classroom.
  // 1:1 with Booking; cascade-deletes if the booking is removed.
  classroomSession ClassroomSession?

  @@index([studentId])
  @@index([tutorId])
  @@index([startTime])
  @@index([lessonId])
  @@index([organizationId])
}

// ========== LIVE CLASSROOM (LiveKit) ==========

enum ClassroomSessionStatus {
  PENDING
  LIVE
  ENDED
}

// Append-only event types that flow through both the LiveKit data channel and
// this audit table. Real-time delivery is the data channel's job; this row is
// for late-joiner history (chat) and after-the-fact analytics (raise-hand
// patterns, slide-by-slide engagement). POLL_OPEN/POLL_VOTE/REACTION/
// PERMISSION_GRANT are declared for the P3 polish phase so we don't migrate
// the enum twice.
enum ClassroomEventType {
  SLIDE_SET
  CHAT_MSG
  HAND_RAISE
  HAND_LOWER
  POLL_OPEN
  POLL_VOTE
  REACTION
  PERMISSION_GRANT
}

// A live virtual classroom riding on top of a Booking. The Booking is the
// scheduling artefact; this row is the runtime artefact (room name, current
// slide, lifecycle status). Created on demand the first time someone joins.
model ClassroomSession {
  id           String                 @id @default(cuid())
  bookingId    String                 @unique
  // Stable LiveKit room name. Reusing a deterministic value across reconnects
  // means we don't end up with two parallel rooms for the same Booking.
  livekitRoom  String                 @unique
  status       ClassroomSessionStatus @default(PENDING)
  // Server-of-truth for the deck position. The tutor's data-channel
  // `slide:set` event is mirrored here so a refresh / late-join can hydrate
  // without depending on the tutor being live at that instant.
  // Shape: { h: number, v: number, f: number } — Reveal's coords.
  currentSlide Json?
  // Set by the post-egress webhook in P3+ when LiveKit finishes uploading the
  // room recording to the configured storage destination. Null while recording
  // is in progress and for sessions that opted not to record.
  recordingUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  booking    Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  attendance ClassroomAttendance[]
  events     ClassroomEvent[]
  polls      ClassroomPoll[]

  @@index([status])
}

// One row per (participant, join). LiveKit's webhook drives this:
// participant_joined → INSERT; participant_left → UPDATE leftAt + durationSec.
// A rejoin creates a new row — we never mutate an existing one — so "did the
// student attend" is just `count(*) > 0` and "for how long" is the sum.
model ClassroomAttendance {
  id          String           @id @default(cuid())
  sessionId   String
  userId      String
  joinedAt    DateTime         @default(now())
  leftAt      DateTime?
  durationSec Int?
  session     ClassroomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

// Append-only audit + history mirror of every meaningful event during a live
// session. Written by the server when it receives a chat/slide/hand event
// from the tutor or student (via authenticated REST call alongside the data
// channel publish). Late joiners GET this table to rebuild chat scrollback.
model ClassroomEvent {
  id        String             @id @default(cuid())
  sessionId String
  // Null for server-emitted events (e.g. an auto SLIDE_SET on session start).
  userId    String?
  type      ClassroomEventType
  payload   Json?
  createdAt DateTime           @default(now())
  session   ClassroomSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([sessionId, type])
}

// Live polls run by the tutor during a classroom session. The tutor opens
// one, students vote, and (optionally) the tutor closes it to lock in
// results. Votes are de-duped by (pollId, userId) — one vote per student.
model ClassroomPoll {
  id        String    @id @default(cuid())
  sessionId String
  // Question + ordered option strings. Options are stored on the row (rather
  // than a separate table) because they're set once at open-time and never
  // mutated; vote counts are derived from ClassroomPollVote rows.
  question  String    @db.Text
  options   String[]
  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  // Tutor who opened the poll. Recorded for audit; not used for auth.
  openedBy  String

  session ClassroomSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  votes   ClassroomPollVote[]

  @@index([sessionId, openedAt])
}

model ClassroomPollVote {
  id          String   @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  votedAt     DateTime @default(now())

  poll ClassroomPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  // One vote per (poll, user). Subsequent calls update the existing row
  // rather than insert duplicates — the service layer handles that upsert.
  @@unique([pollId, userId])
  @@index([pollId])
}

// ========== STEM KITS STORE ==========

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

model Product {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  nameAr        String?
  nameDe        String?
  description   String        @db.Text
  descriptionAr String?       @db.Text
  descriptionDe String?       @db.Text
  price         Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  images        String[]
  ageGroup      AgeGroup
  category      String
  stock         Int           @default(0)
  status        ProductStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orderItems    OrderItem[]

  @@index([slug])
  @@index([category])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  shipping        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  shippingAddress Json?
  stripePaymentId String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ========== COMPETITIONS & EVENTS ==========

enum CompetitionStatus {
  UPCOMING
  REGISTRATION_OPEN
  IN_PROGRESS
  JUDGING
  COMPLETED
}

// Geographic scope of an external event (catalog metadata).
enum EventRegion {
  GLOBAL
  EUROPE
  GERMANY
  US
  UK
}

// Catalog visibility for external events. Distinct from the hosted-competition
// lifecycle (`status`): ACTIVE = listed & promoted, OPTIONAL = listed as a
// stretch/optional opportunity, ARCHIVED = hidden from the public catalog.
enum EventListingStatus {
  ACTIVE
  OPTIONAL
  ARCHIVED
}

// How a course/bundle relates to an event's preparation.
enum EventRecommendationType {
  PREREQUISITE
  RECOMMENDED
  ADVANCED_PREPARATION
}

// The Competition model serves two kinds of record, separated by `isExternal`:
//  - isExternal = false → a SchuLab-HOSTED competition (registration window,
//    scoring, leaderboard, prizes). The date fields drive that flow.
//  - isExternal = true  → a curated entry in the "Events & Competitions" catalog
//    for a reputable EXTERNAL program (FIRST LEGO League, WRO, Astro Pi…). These
//    carry provider/URL/region/season/track metadata and recommendation links,
//    and have no SchuLab-managed registration window (date fields stay null).
// The DB is the single source of truth for all of this metadata — the curriculum
// Git repo only owns the preparation *content*, linked via `preparationPath`.
model Competition {
  id                String            @id @default(cuid())
  slug              String            @unique
  title             String
  titleAr           String?
  titleDe           String?
  description       String            @db.Text
  descriptionAr     String?           @db.Text
  descriptionDe     String?           @db.Text
  thumbnail         String?
  ageGroup          AgeGroup
  category          String
  status            CompetitionStatus @default(UPCOMING)
  // Hosted-competition registration/run window. Nullable because external
  // catalog events have no SchuLab-managed dates (they use seasonMonths).
  registrationStart DateTime?
  registrationEnd   DateTime?
  startDate         DateTime?
  endDate           DateTime?
  maxParticipants   Int?
  prizes            Json?
  rules             String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt

  // ----- External-event catalog metadata (isExternal = true) -----
  isExternal        Boolean            @default(false)
  eventType         String? // e.g. "Robotics / STEM Challenge"
  officialProvider  String?
  officialUrl       String?
  region            EventRegion?
  tracks            String[]           @default([]) // Robotics, Coding, AI, Space…
  seasonMonths      Int[]              @default([]) // months 1–12 the event typically runs
  ageMin            Int? // precise span; ageGroup keeps a representative band
  ageMax            Int?
  levelMin          CourseLevel?
  levelMax          CourseLevel?
  listingStatus     EventListingStatus @default(ACTIVE)
  // Free-form machine-readable gate, shaped { minAge, maxAge, tracks[], notes }.
  eligibilityRules  Json?
  // Optional in-DB preparation journey (NOT the curriculum repo).
  preparationPathId String?
  preparationPath   LearningPathway?   @relation("EventPrepPath", fields: [preparationPathId], references: [id], onDelete: SetNull)

  registrations         CompetitionRegistration[]
  courseRecommendations EventCourseRecommendation[]
  bundleRecommendations EventBundleRecommendation[]

  @@index([slug])
  @@index([status])
  @@index([isExternal, listingStatus])
}

// A course that prepares a learner for an event. The reason/threshold fields let
// the eligibility engine decide whether a completed course satisfies the event.
model EventCourseRecommendation {
  id                          String                  @id @default(cuid())
  competitionId               String
  courseId                    String
  recommendationType          EventRecommendationType @default(RECOMMENDED)
  reason                      String                  @db.Text
  minimumCompletionPercentage Int                     @default(100)
  requiredAssessmentScore     Int?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  competition                 Competition             @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  course                      Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([competitionId, courseId])
  @@index([courseId])
}

// A bundle that prepares a learner for an event. Same shape as the course join.
model EventBundleRecommendation {
  id                          String                  @id @default(cuid())
  competitionId               String
  bundleId                    String
  recommendationType          EventRecommendationType @default(RECOMMENDED)
  reason                      String                  @db.Text
  minimumCompletionPercentage Int                     @default(100)
  requiredAssessmentScore     Int?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  competition                 Competition             @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  bundle                      Bundle                  @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([competitionId, bundleId])
  @@index([bundleId])
}

model CompetitionRegistration {
  id            String      @id @default(cuid())
  competitionId String
  userId        String
  teamName      String?
  submissionUrl String?
  score         Int?
  rank          Int?
  registeredAt  DateTime    @default(now())
  competition   Competition @relation(fields: [competitionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([competitionId, userId])
}

// ========== GAMIFICATION ==========

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  nameAr      String?
  nameDe      String?
  description String
  icon        String
  criteria    Json
  points      Int         @default(0)
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

enum PointAction {
  LESSON_COMPLETED
  QUIZ_PASSED
  COURSE_COMPLETED
  BADGE_EARNED
  COMPETITION_PARTICIPATED
  DAILY_LOGIN
}

model PointTransaction {
  id        String      @id @default(cuid())
  userId    String
  action    PointAction
  points    Int
  metadata  Json?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ========== NOTIFICATIONS & MESSAGES ==========

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  subject    String?
  body       String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([receiverId, isRead])
  @@index([senderId])
}

// ========== CMS PAGES ==========

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  titleAr     String?
  titleDe     String?
  content     String   @db.Text
  contentAr   String?  @db.Text
  contentDe   String?  @db.Text
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ========== HELP & DOCUMENTATION ==========

enum HelpCategory {
  GETTING_STARTED
  FEATURES_OVERVIEW
  GUIDES
  FAQ
  TROUBLESHOOTING
  WHATS_COMING
}

model HelpArticle {
  id          String         @id @default(cuid())
  slug        String         @unique
  category    HelpCategory
  title       String
  titleAr     String?
  titleDe     String?
  excerpt     String         @db.Text
  excerptAr   String?        @db.Text
  excerptDe   String?        @db.Text
  content     String         @db.Text
  contentAr   String?        @db.Text
  contentDe   String?        @db.Text
  tags        String[]
  order       Int            @default(0)
  isPublished Boolean        @default(false)
  isFeatured  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  feedback    HelpFeedback[]

  @@index([slug])
  @@index([category])
  @@index([isPublished])
}

model HelpFeedback {
  id        String      @id @default(cuid())
  articleId String
  helpful   Boolean
  createdAt DateTime    @default(now())
  article   HelpArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model HelpSearchLog {
  id           String   @id @default(cuid())
  query        String
  resultsCount Int      @default(0)
  locale       String   @default("en")
  createdAt    DateTime @default(now())

  @@index([query])
  @@index([locale])
}

// ========== PERMISSIONS & ROLES ==========

model Permission {
  id          String @id @default(cuid())
  name        String @unique
  description String
  resource    String // e.g. "courses", "users", "products", "settings"
  action      String // e.g. "create", "read", "update", "delete", "manage"

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

// ========== SYSTEM SETTINGS ==========

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // string, number, boolean, json
  category    String   @default("general") // general, email, payments, branding, notifications
  label       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([key])
}

// ========== BILLING & SUBSCRIPTIONS ==========

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum PlanTier {
  FREE
  LEARNER
  PRO
  LIFETIME
}

// Catalog of purchasable plans. One Plan row per (tier, interval, currency).
// Stripe price IDs are stored here so checkout sessions can reference them
// without hard-coding identifiers in application code.
model Plan {
  id              String        @id @default(cuid())
  slug            String        @unique
  tier            PlanTier
  interval        PlanInterval?
  name            String
  nameAr          String?
  nameDe          String?
  description     String        @db.Text
  descriptionAr   String?       @db.Text
  descriptionDe   String?       @db.Text
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  stripePriceId   String?       @unique
  stripeProductId String?
  features        Json
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  trialDays       Int           @default(0)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  subscriptions Subscription[]

  @@index([tier])
  @@index([isActive])
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  EXPIRED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(INCOMPLETE)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
}

enum CoursePurchaseStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

// Represents a one-time course purchase separately from Order (STEM-kit
// fulfilment flow). Keeps commerce semantics clean and makes refunds /
// revenue reporting per-learner queryable.
model CoursePurchase {
  id                    String               @id @default(cuid())
  userId                String
  // When set, the enrollment created by the webhook goes to beneficiaryUserId
  // instead of userId (parent-buys-for-child path). Null means self-purchase.
  beneficiaryUserId     String?
  courseId              String
  status                CoursePurchaseStatus @default(PENDING)
  amount                Decimal              @db.Decimal(10, 2)
  currency              String               @default("USD")
  stripeCheckoutId      String?              @unique
  stripePaymentIntentId String?              @unique
  paidAt                DateTime?
  refundedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user        User     @relation("CoursePurchasePayer", fields: [userId], references: [id])
  beneficiary User?    @relation("CoursePurchaseBeneficiary", fields: [beneficiaryUserId], references: [id])
  invoice     Invoice?

  @@unique([userId, courseId, beneficiaryUserId, status])
  @@index([userId])
  @@index([beneficiaryUserId])
  @@index([courseId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
  REFUNDED
}

enum InvoiceKind {
  SUBSCRIPTION
  COURSE
  ORDER
}

model Invoice {
  id               String        @id @default(cuid())
  userId           String
  subscriptionId   String?
  coursePurchaseId String?       @unique
  orderId          String?       @unique
  kind             InvoiceKind
  status           InvoiceStatus @default(OPEN)
  number           String        @unique
  subtotal         Decimal       @db.Decimal(10, 2)
  tax              Decimal       @default(0) @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  stripeInvoiceId  String?       @unique
  hostedUrl        String?
  pdfUrl           String?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  user           User            @relation(fields: [userId], references: [id])
  subscription   Subscription?   @relation(fields: [subscriptionId], references: [id])
  coursePurchase CoursePurchase? @relation(fields: [coursePurchaseId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

// ========== CONSENT & COMPLIANCE ==========

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  PARENTAL_COPPA
  PARENTAL_GDPR_K
  MARKETING_EMAIL
  MARKETING_SMS
  COOKIES_ANALYTICS
  COOKIES_MARKETING
}

// Single append-only ledger of every consent event. Withdrawal is modelled
// as a new record with granted=false, so we retain the full audit trail.
model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  grantedById String?
  type        ConsentType
  granted     Boolean
  version     String
  documentUrl String?
  ipAddress   String?
  userAgent   String?     @db.Text
  grantedAt   DateTime    @default(now())
  expiresAt   DateTime?

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("ConsentGivenBy", fields: [grantedById], references: [id])

  @@index([userId, type])
  @@index([type])
}

// ========== VIDEO ASSETS ==========

enum VideoProvider {
  MUX
  CLOUDFLARE_STREAM
  VIMEO
  YOUTUBE
  EXTERNAL
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
}

// Provider-agnostic record for every video in the system. Lessons point at
// these instead of raw URLs so we can swap providers, rotate signed URLs,
// and track DRM + captions uniformly.
model VideoAsset {
  id           String        @id @default(cuid())
  provider     VideoProvider
  providerId   String
  playbackId   String?
  uploadUrl    String?       @db.Text
  thumbnail    String?
  duration     Int?
  status       VideoStatus   @default(UPLOADING)
  hasCaptions  Boolean       @default(false)
  drmProtected Boolean       @default(false)
  languages    String[]
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([provider, providerId])
  @@index([status])
}

// ========== ANALYTICS EVENTS ==========

// Local append-only mirror of key product-analytics events. Useful for
// server-side funnels when the external provider (PostHog/GA4) is not yet
// wired or for privacy-sensitive regions where client instrumentation is
// restricted.
model AnalyticsEvent {
  id          String   @id @default(cuid())
  userId      String?
  anonymousId String?
  name        String
  properties  Json?
  context     Json?
  occurredAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([name])
  @@index([occurredAt])
}

// ========== COURSE REVIEWS ==========

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model CourseReview {
  id           String       @id @default(cuid())
  courseId     String
  userId       String
  rating       Int
  title        String?
  body         String?      @db.Text
  status       ReviewStatus @default(PENDING)
  helpfulCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId, status])
  @@index([userId])
}

// ========== COUPONS ==========

enum CouponType {
  PERCENT
  FIXED
}

enum CouponScope {
  ALL
  COURSE
  PLAN
}

model Coupon {
  id             String      @id @default(cuid())
  code           String      @unique
  type           CouponType
  value          Decimal     @db.Decimal(10, 2)
  currency       String?
  scope          CouponScope @default(ALL)
  appliesToId    String?
  maxRedemptions Int?
  usedCount      Int         @default(0)
  perUserLimit   Int         @default(1)
  minAmount      Decimal?    @db.Decimal(10, 2)
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean     @default(true)
  stripeCouponId String?     @unique
  stripePromoId  String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive])
}

model CouponRedemption {
  id               String   @id @default(cuid())
  couponId         String
  userId           String
  coursePurchaseId String?
  subscriptionId   String?
  amountOff        Decimal  @db.Decimal(10, 2)
  currency         String   @default("USD")
  redeemedAt       DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A single coupon can only be redeemed once per purchase / subscription,
  // so webhook retries don't double-count usage. These partial-unique indexes
  // are tolerant of the NULL column on the "other" target.
  @@unique([couponId, coursePurchaseId])
  @@unique([couponId, subscriptionId])
  @@index([couponId])
  @@index([userId])
}

// ========== AUDIT LOG ==========

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
}

// ========== ONBOARDING ==========

model OnboardingProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  goals             String[]
  interests         String[]
  preferredSubjects String[]
  availableHours    Int?
  experience        String?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ========== LIFECYCLE DRIP ==========

enum DripJourney {
  ACTIVATION
  PARENT_DIGEST
  CART_ABANDONMENT
  WIN_BACK
}

enum DripStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model DripState {
  id         String      @id @default(cuid())
  userId     String
  journey    DripJourney
  step       Int         @default(0)
  status     DripStatus  @default(ACTIVE)
  nextSendAt DateTime?
  lastSentAt DateTime?
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, journey])
  @@index([journey, status, nextSendAt])
}

// Idempotency ledger for Stripe (and future) webhook events. The provider's
// event id is the primary key; a unique-violation on insert means the event
// has already been processed and the handler can short-circuit safely.
model WebhookEvent {
  id          String   @id
  provider    String   @default("stripe")
  type        String
  processedAt DateTime @default(now())

  @@index([provider, processedAt])
}
