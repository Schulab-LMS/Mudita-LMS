generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ========== AUTH & USERS ==========

enum Role {
  STUDENT
  PARENT
  TUTOR
  ADMIN
  SUPER_ADMIN
  B2B_PARTNER
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  passwordHash     String?
  name             String
  avatar           String?
  role             Role      @default(STUDENT)
  locale           String    @default("en")
  isActive         Boolean   @default(true)
  dateOfBirth      DateTime?
  stripeCustomerId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile      Profile?
  tutorProfile TutorProfile?
  enrollments  Enrollment[]
  progress     LessonProgress[]
  quizAttempts QuizAttempt[]
  certificates Certificate[]
  badges       UserBadge[]
  points       PointTransaction[]

  bookingsAsStudent Booking[]                 @relation("StudentBookings")
  orders            Order[]
  coursePurchases   CoursePurchase[]
  subscriptions     Subscription[]
  invoices          Invoice[]
  notifications     Notification[]
  sentMessages      Message[]                 @relation("SentMessages")
  receivedMessages  Message[]                 @relation("ReceivedMessages")
  competitionRegs   CompetitionRegistration[]
  consentRecords    ConsentRecord[]
  analyticsEvents   AnalyticsEvent[]

  parentOf      ParentChild[]   @relation("ParentRelation")
  childOf       ParentChild[]   @relation("ChildRelation")
  consentsGiven ConsentRecord[] @relation("ConsentGivenBy")

  courseReviews     CourseReview[]
  couponRedemptions CouponRedemption[]
  auditLogs         AuditLog[]
  onboardingProfile OnboardingProfile?
  dripStates        DripState[]

  accounts Account[]
  sessions Session[]

  @@index([email])
  @@index([role])
  @@index([stripeCustomerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  bio         String?   @db.Text
  dateOfBirth DateTime?
  grade       String?
  school      String?
  country     String?
  phone       String?
  interests   String[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParentChild {
  id       String @id @default(cuid())
  parentId String
  childId  String
  parent   User   @relation("ParentRelation", fields: [parentId], references: [id])
  child    User   @relation("ChildRelation", fields: [childId], references: [id])

  createdAt DateTime @default(now())

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

// ========== COURSES & CONTENT ==========

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Lifecycle marker for Git-synced curriculum entities. Removal from the
// source repo flips this to REMOVED (soft-archive) instead of deleting the
// row, so dependent LessonProgress / QuizAttempt records are never lost.
enum SyncStatus {
  ACTIVE
  REMOVED
}

enum AgeGroup {
  AGES_3_5
  AGES_6_8
  AGES_9_12
  AGES_13_15
  AGES_16_18
}

model Course {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  titleAr       String?
  titleDe       String?
  description   String       @db.Text
  descriptionAr String?      @db.Text
  descriptionDe String?      @db.Text
  thumbnail     String?
  previewVideo  String?
  level         CourseLevel  @default(BEGINNER)
  ageGroup      AgeGroup
  category      String
  tags          String[]
  price         Decimal      @default(0) @db.Decimal(10, 2)
  currency      String       @default("USD")
  isFree        Boolean      @default(false)
  // Marks a course as included with an active subscription whose plan tier
  // is >= the value set here. Nullable by design: the historical model is
  // "free (isFree) OR one-time purchase (price)", and we keep that working
  // untouched when requiredPlan is null. Tier order is FREE < LEARNER < PRO
  // < LIFETIME — see src/lib/subscription-access.ts.
  requiredPlan  PlanTier?
  status        CourseStatus @default(DRAFT)
  duration      Int?
  averageRating Decimal      @default(0) @db.Decimal(3, 2)
  reviewCount   Int          @default(0)
  createdById   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Git-managed curriculum provenance. `managedByGit` flags a course whose
  // content is owned by the STEM-Curricula repo (read-only in the admin UI).
  // `sourcePath` is the course folder in the repo; `sourceCommitSha` is the
  // commit last synced. See src/services/curriculum-sync.service.ts.
  managedByGit    Boolean    @default(false)
  sourcePath      String?
  sourceCommitSha String?
  syncStatus      SyncStatus @default(ACTIVE)

  modules     Module[]
  enrollments Enrollment[]
  reviews     CourseReview[]

  @@index([slug])
  @@index([category])
  @@index([ageGroup])
  @@index([status])
  @@index([requiredPlan])
  @@index([managedByGit])
}

model Module {
  id         String     @id @default(cuid())
  courseId   String
  title      String
  titleAr    String?
  titleDe    String?
  order      Int
  sourcePath String?
  syncStatus SyncStatus @default(ACTIVE)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  // Stable upsert key for Git-synced modules (NULL for admin-created ones;
  // Postgres treats NULLs as distinct, so non-managed rows are unaffected).
  @@unique([courseId, sourcePath])
  @@index([courseId])
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  INTERACTIVE
  ASSIGNMENT
}

model Lesson {
  id           String           @id @default(cuid())
  moduleId     String
  title        String
  titleAr      String?
  titleDe      String?
  content      String?          @db.Text
  contentAr    String?          @db.Text
  contentDe    String?          @db.Text
  // Hands-on take-home activity (synced from activity.md). Student-visible.
  activity     String?          @db.Text
  activityAr   String?          @db.Text
  activityDe   String?          @db.Text
  // Tutor-only guidance (module overview + TUTOR_ONLY fences). NEVER served
  // to students — student-facing queries omit these columns by construction.
  tutorNotes   String?          @db.Text
  tutorNotesAr String?          @db.Text
  tutorNotesDe String?          @db.Text
  videoUrl     String?
  videoAssetId String?
  thumbnail    String?
  duration     Int?
  type         LessonType       @default(VIDEO)
  order        Int
  isFree       Boolean          @default(false)
  sourcePath   String?
  syncStatus   SyncStatus       @default(ACTIVE)
  module       Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz         Quiz?
  progress     LessonProgress[]
  sessions     Booking[]

  // Stable upsert key for Git-synced lessons (NULL for admin-created ones).
  @@unique([moduleId, sourcePath])
  @@index([moduleId])
  @@index([videoAssetId])
}

// ========== QUIZZES ==========

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

model Quiz {
  id           String        @id @default(cuid())
  lessonId     String        @unique
  title        String
  passingScore Int           @default(70)
  timeLimit    Int?
  lesson       Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]
}

model Question {
  id          String       @id @default(cuid())
  quizId      String
  text        String       @db.Text
  textAr      String?      @db.Text
  textDe      String?      @db.Text
  type        QuestionType @default(MULTIPLE_CHOICE)
  points      Int          @default(1)
  order       Int
  explanation String?      @db.Text
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     Answer[]

  @@index([quizId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  text       String
  textAr     String?
  textDe     String?
  isCorrect  Boolean  @default(false)
  order      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  answers     Json
  passed      Boolean
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([quizId])
}

// ========== ENROLLMENT & PROGRESS ==========

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  user        User             @relation(fields: [userId], references: [id])
  course      Course           @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  completed  Boolean  @default(false)
  timeSpent  Int      @default(0)
  lastAccess DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  lesson     Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId])
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  courseId String
  code     String   @unique
  issuedAt DateTime @default(now())
  pdfUrl   String?
  user     User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([code])
}

// ========== CURRICULUM SYNC (Git) ==========

enum SyncRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SyncTrigger {
  WEBHOOK
  MANUAL
  CRON
}

// One row per curriculum sync attempt. Observability + admin "last synced"
// display. Written by src/services/curriculum-sync.service.ts.
model CurriculumSyncRun {
  id               String        @id @default(cuid())
  commitSha        String?
  status           SyncRunStatus @default(RUNNING)
  trigger          SyncTrigger
  coursesUpserted  Int           @default(0)
  lessonsUpserted  Int           @default(0)
  coursesArchived  Int           @default(0)
  error            String?       @db.Text
  startedAt        DateTime      @default(now())
  finishedAt       DateTime?

  @@index([startedAt])
}

// ========== TUTORING ==========

model TutorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  headline      String?
  bio           String?  @db.Text
  subjects      String[]
  languages     String[]
  hourlyRate    Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  rating        Decimal  @default(0) @db.Decimal(3, 2)
  totalSessions Int      @default(0)
  isVerified    Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  availability TutorAvailability[]
  bookings     Booking[]
}

model TutorAvailability {
  id        String       @id @default(cuid())
  tutorId   String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String       @default("UTC")
  tutor     TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Booking {
  id         String        @id @default(cuid())
  studentId  String
  tutorId    String
  subject    String
  startTime  DateTime
  endTime    DateTime
  status     BookingStatus @default(PENDING)
  meetingUrl String?
  meetingId  String?
  notes      String?       @db.Text
  rating     Int?
  review     String?       @db.Text
  price      Decimal       @db.Decimal(10, 2)
  currency   String        @default("USD")
  createdAt  DateTime      @default(now())
  // The curriculum lesson taught in this session (set by the tutor). Drives
  // the role-split live-session view. Null until the tutor assigns one.
  lessonId   String?
  student    User          @relation("StudentBookings", fields: [studentId], references: [id])
  tutor      TutorProfile  @relation(fields: [tutorId], references: [id])
  lesson     Lesson?       @relation(fields: [lessonId], references: [id])

  @@index([studentId])
  @@index([tutorId])
  @@index([startTime])
  @@index([lessonId])
}

// ========== STEM KITS STORE ==========

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

model Product {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  nameAr        String?
  nameDe        String?
  description   String        @db.Text
  descriptionAr String?       @db.Text
  descriptionDe String?       @db.Text
  price         Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  images        String[]
  ageGroup      AgeGroup
  category      String
  stock         Int           @default(0)
  status        ProductStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orderItems    OrderItem[]

  @@index([slug])
  @@index([category])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  shipping        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  shippingAddress Json?
  stripePaymentId String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ========== COMPETITIONS ==========

enum CompetitionStatus {
  UPCOMING
  REGISTRATION_OPEN
  IN_PROGRESS
  JUDGING
  COMPLETED
}

model Competition {
  id                String                    @id @default(cuid())
  slug              String                    @unique
  title             String
  titleAr           String?
  titleDe           String?
  description       String                    @db.Text
  descriptionAr     String?                   @db.Text
  descriptionDe     String?                   @db.Text
  thumbnail         String?
  ageGroup          AgeGroup
  category          String
  status            CompetitionStatus         @default(UPCOMING)
  registrationStart DateTime
  registrationEnd   DateTime
  startDate         DateTime
  endDate           DateTime
  maxParticipants   Int?
  prizes            Json?
  rules             String?                   @db.Text
  createdAt         DateTime                  @default(now())
  registrations     CompetitionRegistration[]

  @@index([slug])
  @@index([status])
}

model CompetitionRegistration {
  id            String      @id @default(cuid())
  competitionId String
  userId        String
  teamName      String?
  submissionUrl String?
  score         Int?
  rank          Int?
  registeredAt  DateTime    @default(now())
  competition   Competition @relation(fields: [competitionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([competitionId, userId])
}

// ========== GAMIFICATION ==========

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  nameAr      String?
  nameDe      String?
  description String
  icon        String
  criteria    Json
  points      Int         @default(0)
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

enum PointAction {
  LESSON_COMPLETED
  QUIZ_PASSED
  COURSE_COMPLETED
  BADGE_EARNED
  COMPETITION_PARTICIPATED
  DAILY_LOGIN
}

model PointTransaction {
  id        String      @id @default(cuid())
  userId    String
  action    PointAction
  points    Int
  metadata  Json?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ========== NOTIFICATIONS & MESSAGES ==========

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  subject    String?
  body       String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([receiverId, isRead])
  @@index([senderId])
}

// ========== CMS PAGES ==========

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  titleAr     String?
  titleDe     String?
  content     String   @db.Text
  contentAr   String?  @db.Text
  contentDe   String?  @db.Text
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ========== HELP & DOCUMENTATION ==========

enum HelpCategory {
  GETTING_STARTED
  FEATURES_OVERVIEW
  GUIDES
  FAQ
  TROUBLESHOOTING
  WHATS_COMING
}

model HelpArticle {
  id          String         @id @default(cuid())
  slug        String         @unique
  category    HelpCategory
  title       String
  titleAr     String?
  titleDe     String?
  excerpt     String         @db.Text
  excerptAr   String?        @db.Text
  excerptDe   String?        @db.Text
  content     String         @db.Text
  contentAr   String?        @db.Text
  contentDe   String?        @db.Text
  tags        String[]
  order       Int            @default(0)
  isPublished Boolean        @default(false)
  isFeatured  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  feedback    HelpFeedback[]

  @@index([slug])
  @@index([category])
  @@index([isPublished])
}

model HelpFeedback {
  id        String      @id @default(cuid())
  articleId String
  helpful   Boolean
  createdAt DateTime    @default(now())
  article   HelpArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model HelpSearchLog {
  id           String   @id @default(cuid())
  query        String
  resultsCount Int      @default(0)
  locale       String   @default("en")
  createdAt    DateTime @default(now())

  @@index([query])
  @@index([locale])
}

// ========== PERMISSIONS & ROLES ==========

model Permission {
  id          String @id @default(cuid())
  name        String @unique
  description String
  resource    String // e.g. "courses", "users", "products", "settings"
  action      String // e.g. "create", "read", "update", "delete", "manage"

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

// ========== SYSTEM SETTINGS ==========

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // string, number, boolean, json
  category    String   @default("general") // general, email, payments, branding, notifications
  label       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([key])
}

// ========== BILLING & SUBSCRIPTIONS ==========

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum PlanTier {
  FREE
  LEARNER
  PRO
  LIFETIME
}

// Catalog of purchasable plans. One Plan row per (tier, interval, currency).
// Stripe price IDs are stored here so checkout sessions can reference them
// without hard-coding identifiers in application code.
model Plan {
  id              String        @id @default(cuid())
  slug            String        @unique
  tier            PlanTier
  interval        PlanInterval?
  name            String
  nameAr          String?
  nameDe          String?
  description     String        @db.Text
  descriptionAr   String?       @db.Text
  descriptionDe   String?       @db.Text
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  stripePriceId   String?       @unique
  stripeProductId String?
  features        Json
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  trialDays       Int           @default(0)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  subscriptions Subscription[]

  @@index([tier])
  @@index([isActive])
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  EXPIRED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(INCOMPLETE)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
}

enum CoursePurchaseStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

// Represents a one-time course purchase separately from Order (STEM-kit
// fulfilment flow). Keeps commerce semantics clean and makes refunds /
// revenue reporting per-learner queryable.
model CoursePurchase {
  id                    String               @id @default(cuid())
  userId                String
  courseId              String
  status                CoursePurchaseStatus @default(PENDING)
  amount                Decimal              @db.Decimal(10, 2)
  currency              String               @default("USD")
  stripeCheckoutId      String?              @unique
  stripePaymentIntentId String?              @unique
  paidAt                DateTime?
  refundedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  invoice Invoice?

  @@unique([userId, courseId, status])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
  REFUNDED
}

enum InvoiceKind {
  SUBSCRIPTION
  COURSE
  ORDER
}

model Invoice {
  id               String        @id @default(cuid())
  userId           String
  subscriptionId   String?
  coursePurchaseId String?       @unique
  orderId          String?       @unique
  kind             InvoiceKind
  status           InvoiceStatus @default(OPEN)
  number           String        @unique
  subtotal         Decimal       @db.Decimal(10, 2)
  tax              Decimal       @default(0) @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  stripeInvoiceId  String?       @unique
  hostedUrl        String?
  pdfUrl           String?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  user           User            @relation(fields: [userId], references: [id])
  subscription   Subscription?   @relation(fields: [subscriptionId], references: [id])
  coursePurchase CoursePurchase? @relation(fields: [coursePurchaseId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

// ========== CONSENT & COMPLIANCE ==========

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  PARENTAL_COPPA
  PARENTAL_GDPR_K
  MARKETING_EMAIL
  MARKETING_SMS
  COOKIES_ANALYTICS
  COOKIES_MARKETING
}

// Single append-only ledger of every consent event. Withdrawal is modelled
// as a new record with granted=false, so we retain the full audit trail.
model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  grantedById String?
  type        ConsentType
  granted     Boolean
  version     String
  documentUrl String?
  ipAddress   String?
  userAgent   String?     @db.Text
  grantedAt   DateTime    @default(now())
  expiresAt   DateTime?

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("ConsentGivenBy", fields: [grantedById], references: [id])

  @@index([userId, type])
  @@index([type])
}

// ========== VIDEO ASSETS ==========

enum VideoProvider {
  MUX
  CLOUDFLARE_STREAM
  VIMEO
  YOUTUBE
  EXTERNAL
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
}

// Provider-agnostic record for every video in the system. Lessons point at
// these instead of raw URLs so we can swap providers, rotate signed URLs,
// and track DRM + captions uniformly.
model VideoAsset {
  id           String        @id @default(cuid())
  provider     VideoProvider
  providerId   String
  playbackId   String?
  uploadUrl    String?       @db.Text
  thumbnail    String?
  duration     Int?
  status       VideoStatus   @default(UPLOADING)
  hasCaptions  Boolean       @default(false)
  drmProtected Boolean       @default(false)
  languages    String[]
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([provider, providerId])
  @@index([status])
}

// ========== ANALYTICS EVENTS ==========

// Local append-only mirror of key product-analytics events. Useful for
// server-side funnels when the external provider (PostHog/GA4) is not yet
// wired or for privacy-sensitive regions where client instrumentation is
// restricted.
model AnalyticsEvent {
  id          String   @id @default(cuid())
  userId      String?
  anonymousId String?
  name        String
  properties  Json?
  context     Json?
  occurredAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([name])
  @@index([occurredAt])
}

// ========== COURSE REVIEWS ==========

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model CourseReview {
  id           String       @id @default(cuid())
  courseId     String
  userId       String
  rating       Int
  title        String?
  body         String?      @db.Text
  status       ReviewStatus @default(PENDING)
  helpfulCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId, status])
  @@index([userId])
}

// ========== COUPONS ==========

enum CouponType {
  PERCENT
  FIXED
}

enum CouponScope {
  ALL
  COURSE
  PLAN
}

model Coupon {
  id             String      @id @default(cuid())
  code           String      @unique
  type           CouponType
  value          Decimal     @db.Decimal(10, 2)
  currency       String?
  scope          CouponScope @default(ALL)
  appliesToId    String?
  maxRedemptions Int?
  usedCount      Int         @default(0)
  perUserLimit   Int         @default(1)
  minAmount      Decimal?    @db.Decimal(10, 2)
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean     @default(true)
  stripeCouponId String?     @unique
  stripePromoId  String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive])
}

model CouponRedemption {
  id               String   @id @default(cuid())
  couponId         String
  userId           String
  coursePurchaseId String?
  subscriptionId   String?
  amountOff        Decimal  @db.Decimal(10, 2)
  currency         String   @default("USD")
  redeemedAt       DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A single coupon can only be redeemed once per purchase / subscription,
  // so webhook retries don't double-count usage. These partial-unique indexes
  // are tolerant of the NULL column on the "other" target.
  @@unique([couponId, coursePurchaseId])
  @@unique([couponId, subscriptionId])
  @@index([couponId])
  @@index([userId])
}

// ========== AUDIT LOG ==========

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
}

// ========== ONBOARDING ==========

model OnboardingProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  goals             String[]
  interests         String[]
  preferredSubjects String[]
  availableHours    Int?
  experience        String?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ========== LIFECYCLE DRIP ==========

enum DripJourney {
  ACTIVATION
  PARENT_DIGEST
  CART_ABANDONMENT
  WIN_BACK
}

enum DripStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model DripState {
  id         String      @id @default(cuid())
  userId     String
  journey    DripJourney
  step       Int         @default(0)
  status     DripStatus  @default(ACTIVE)
  nextSendAt DateTime?
  lastSentAt DateTime?
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, journey])
  @@index([journey, status, nextSendAt])
}

// Idempotency ledger for Stripe (and future) webhook events. The provider's
// event id is the primary key; a unique-violation on insert means the event
// has already been processed and the handler can short-circuit safely.
model WebhookEvent {
  id          String   @id
  provider    String   @default("stripe")
  type        String
  processedAt DateTime @default(now())

  @@index([provider, processedAt])
}
