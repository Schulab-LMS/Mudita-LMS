  "about": {
    "title": "About Schulab",
    "subtitle": "We believe every child deserves access to joyful, high-quality STEM education — no matter where they live or what language they speak.",
    "storyTitle": "Our Story",
    "storyText": "Schulab was born from a simple belief: traditional school teaches facts, but the next era of learning teaches children how to build the future. We set out to turn every classroom into a lab — where science, coding, and engineering feel like an adventure, not a chore. By combining expert instruction, interactive technology, and hands-on experiments, we created a platform where curiosity becomes capability.",
    "mission": {
      "title": "Our Mission",
      "text": "To make STEM education accessible, engaging, and fun for every child worldwide. We combine expert instruction with interactive technology and hands-on kits to spark curiosity and build future-ready skills."
    },
    "vision": {
      "title": "Our Vision",
      "text": "A world where every child — regardless of background, language, or location — has the opportunity to explore science, technology, engineering, and mathematics through joyful learning experiences."
    },
    "values": {
      "title": "Our Values",
      "joy": "Joy First",
      "joyDesc": "Learning should feel like play. We design every experience to spark excitement and wonder.",
      "access": "Accessibility",
      "accessDesc": "STEM education for every child, everywhere. Multilingual, affordable, and inclusive.",
      "quality": "Quality",
      "qualityDesc": "Expert-designed courses, vetted tutors, and rigorous content standards.",
      "safety": "Safety",
      "safetyDesc": "Children's privacy and safety are non-negotiable. We exceed industry standards."
    },
    "methodology": {
      "title": "Our Approach to Learning",
      "text": "Every Schulab course follows a proven learn-practice-apply framework. Children watch engaging video lessons, reinforce concepts through interactive quizzes, and then apply what they've learned through hands-on projects and STEM kit activities. This multi-modal approach ensures deeper understanding and retention."
    },
